# ─── Telegram API credentials ───────────────────────────────────────────────
# Get these from https://my.telegram.org
API_ID=your_api_id
API_HASH=your_api_hash

# ─── Bot Token ───────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
BOT_TOKEN=your_bot_token

# ─── Pyrogram String Session ─────────────────────────────────────────────────
# Generate this for the assistant (userbot) account.
# See README.md > "How to Generate a String Session"
STRING_SESSION=your_string_session

# ─── Sudo Users ──────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs that have full bot control
SUDO_USERS=your_user_id

# ─── Optional ────────────────────────────────────────────────────────────────
# Path to a Netscape-format cookies file to bypass YouTube age/region gates
# YT_COOKIES_FILE=/path/to/cookies.txt
